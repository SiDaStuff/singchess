{
  "name": "sidastuff-chess-review",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "node scripts/build-pieces.mjs && node scripts/copy-stockfish.mjs && node scripts/build-puzzles.mjs",
    "build:pieces": "node scripts/build-pieces.mjs",
    "build:puzzles": "node scripts/build-puzzles.mjs",
    "start": "node server/index.js",
    "dev": "node server/dev.js",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop chess-review || true",
    "pm2:restart": "pm2 restart chess-review",
    "pm2:logs": "pm2 logs chess-review --lines 200"
  },
  "dependencies": {
    "chess.js": "^0.10.3",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "firebase-admin": "^12.0.0",
    "fzstd": "^0.1.1",
    "morgan": "^1.10.0",
    "sql.js": "^1.14.1",
    "stockfish": "^18.0.7"
  }
}

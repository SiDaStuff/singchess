# ──────────────────────────────────────────────────────────────────────────
# SiDaStuff Chess Review — environment variables.
# Copy this file to `.env` (at the REPO ROOT) and fill in real values.
# The server loads the root .env (server/index.cjs); `npm run dev` (Vite) reads
# VITE_* vars from the same file. NEVER commit a real .env — it is gitignored.
# ──────────────────────────────────────────────────────────────────────────

# ── Firebase (Admin SDK) — REQUIRED for auth, profiles, quota, everything ──
# Full service-account JSON as a single line (escape newlines as \n) or base64.
# Get it from Firebase Console → Project settings → Service accounts → Generate.
SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n",...}
# Your Realtime Database URL (without trailing slash).
REALTIME_DATABASE_URL=https://<project>-default-rtdb.firebaseio.com

# ── AI Coach LLM providers — at least ONE key is required for the Coach ────
# Provider chain: fast = llm7 → Cerebras → Groq → Mistral; strong = Cerebras → Groq → Mistral.
# llm7.io (fast-tier primary)
LLM_API_KEY=
# Cerebras (fast + strong)
CEREBRAS_API_KEY=
# Groq (fast + strong)
GROQ_API_KEY=
# Mistral (fast + strong fallback)
MISTRAL_API_KEY=

# ── AI Coach tuning (optional — sensible defaults shown) ───────────────────
# Override model ids per provider/tier if desired (defaults are in llm-service.js).
# CEREBRAS_MODEL_FAST= | CEREBRAS_MODEL_STRONG= | GROQ_MODEL_FAST= | GROQ_MODEL_STRONG=
# MISTRAL_MODEL_FAST= | MISTRAL_MODEL_STRONG= | LLM7_MODEL_FAST=
# Circuit breaker for llm7 (fast primary): open after N failures, cooldown in ms.
# LLM_BREAKER_THRESHOLD=3
# LLM_BREAKER_COOLDOWN_MS=30000

# ── Server Stockfish (server-side review/anticheat analysis) ───────────────
# lite-single (default, fastest at fixed depth) | single (stronger, more RAM).
SERVER_STOCKFISH_ENGINE=lite-single
# Number of UCI threads (default: auto = cores-1, max 4).
# SERVER_STOCKFISH_THREADS=auto

# ── Server runtime (optional — defaults shown) ─────────────────────────────
PORT=3000
# Serve the built frontend from dist/ alongside the API. Set to 0 if a separate
# web server (nginx/CDN) serves static files.
SERVE_STATIC=1
# Set to 1 when behind a trusted reverse proxy (nginx/Cloudflare) so rate limits
# read X-Forwarded-For correctly. REQUIRED in production behind a proxy.
TRUST_PROXY=1
NODE_ENV=production
# Allow extra CORS origins (space-free, comma-free — add to the allowlist in
# server/index.cjs instead for production). Default production origin:
#   https://chess.sidastuff.com  (+ localhost in dev)

# Example server environment variables loaded from server/.env
# Store sensitive values securely in production.

# Firebase service account JSON (single-line JSON string or base64). Example:
# SERVICE_ACCOUNT='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\",...}'
SERVICE_ACCOUNT=
REALTIME_DATABASE_URL=
REALTIME_DATABASE_SECRET=

# Patreon (Boost billing)
# Set redirect URI in Patreon client settings to:
#   https://chess.sidastuff.com/api/patreon/callback
PATREON_CLIENT_ID=
PATREON_CLIENT_SECRET=
PATREON_REDIRECT_URI=https://chess.sidastuff.com/api/patreon/callback

# Optional: prefer the full Stockfish build on the server
SERVER_STOCKFISH_ENGINE=lite
